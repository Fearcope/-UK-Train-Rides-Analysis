    write_table(ws, r, "8B - Refund Rate by Payment Method x Journey Status", b)


def q9(wb, df):
    months = list(df["Month"].cat.categories)
    a = df.groupby("Month").agg(Total_Trips=("Price", "size"), Revenue=("Price", "sum"))
    a["Delayed"] = df[df["Journey Status"] == "Delayed"].groupby("Month").size().reindex(a.index).fillna(0).astype(int)
    a["Cancelled"] = df[df["Journey Status"] == "Cancelled"].groupby("Month").size().reindex(a.index).fillna(0).astype(int)
    a["Delay %"] = (a["Delayed"] / a["Total_Trips"] * 100).round(1)
    a["Cancel %"] = (a["Cancelled"] / a["Total_Trips"] * 100).round(1)
    a["Disruption %"] = (a["Delay %"] + a["Cancel %"]).round(1)
    a["Revenue"] = a["Revenue"].round(0).astype(int)
    a = a.reindex(months).reset_index().rename(columns={"Total_Trips": "Total Trips", "Revenue": "Revenue (£)"})

    delayed = df[df["Journey Status"] == "Delayed"]
