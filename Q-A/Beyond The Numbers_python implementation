    b = delayed.pivot_table(index="Month", columns="Reason for Delay",
                             values="Transaction ID", aggfunc="count", fill_value=0)
    b = b.reindex(index=months, columns=reasons, fill_value=0)
    b["TOTAL"] = b.sum(axis=1)
    b = b.reset_index()

    ws = start_sheet(wb, "Q9 Monthly Trend",
