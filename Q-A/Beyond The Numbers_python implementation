def q11(wb, df):
    a = df.groupby("Arrival Destination").agg(Total_Trips=("Price", "size"))
    a["Cancelled"] = df[df["Journey Status"] == "Cancelled"].groupby(
        "Arrival Destination").size().reindex(a.index).fillna(0).astype(int)
    a["Cancel %"] = (a["Cancelled"] / a["Total_Trips"] * 100).round(1)
    cancelled = df[df["Journey Status"] == "Cancelled"]
    a["Refund Requests"] = cancelled[cancelled["Is Refund"]].groupby(
        "Arrival Destination").size().reindex(a.index).fillna(0).astype(int)
    a["Refund Rate %"] = (a["Refund Requests"] / a["Cancelled"].replace(0, np.nan) * 100).round(1).fillna(0)
    a = a.sort_values("Cancel %", ascending=False).reset_index().rename(columns={"Total_Trips": "Total Trips"})

    b = df.groupby(["Ticket Type", "Ticket Class"]).agg(Total_Trips=("Price", "size"))
    b["Cancelled"] = df[df["Journey Status"] == "Cancelled"].groupby(
        ["Ticket Type", "Ticket Class"]).size().reindex(b.index).fillna(0).astype(int)
    b["Cancel %"] = (b["Cancelled"] / b["Total_Trips"] * 100).round(1)
    b["Refund Rate %"] = (df.groupby(["Ticket Type", "Ticket Class"])["Is Refund"].mean() * 100).round(1)
    b = b.reset_index().rename(columns={"Total_Trips": "Total Trips"})

    ws = start_sheet(wb, "Q11 Cancellations",
                      "Q11 - Where & Why Do Cancellations Happen Most?",
                      "Pivot: Cancellations by Destination | Cancellations by Ticket Type | Cancelled x Refund", 6)
    r = write_table(ws, 4, "11A - Cancellation Rate by Arrival Destination", a)
    write_table(ws, r, "11B - Cancellations by Ticket Type & Class", b)


def q12(wb, df):
    delayed = df[df["Journey Status"] == "Delayed"]
    reasons = sorted(delayed["Reason for Delay"].unique())
    a = delayed.pivot_table(index="Departure Hour", columns="Reason for Delay",
                             values="Transaction ID", aggfunc="count", fill_value=0)
    a = a.reindex(columns=reasons, fill_value=0)
    a["Period"] = a.index.map(lambda h: next(lbl for lo, hi, lbl in TIME_BANDS if lo <= h <= hi) if pd.notna(h) else "-")
    a = a.reset_index().rename(columns={"Departure Hour": "Hour"})
    a = a[["Hour", "Period"] + reasons]

    b = delayed.groupby("Time Band").agg(Total_Delayed=("Transaction ID", "size"))
    totals_band = df.groupby("Time Band").size()
    b["Delay Rate %"] = (b["Total_Delayed"] / b.index.map(totals_band) * 100).round(1)
    dominant = delayed.groupby("Time Band")["Reason for Delay"].agg(
        lambda s: s.value_counts().idxmax() if len(s) else "-")
    counts = delayed.groupby(["Time Band", "Reason for Delay"]).size()
    b["Dominant Reason"] = b.index.map(dominant).fillna("-")
    b["Count"] = [counts.get((band, dom), 0) for band, dom in zip(b.index, b["Dominant Reason"])]
    b["Avg Delay (min)"] = delayed.groupby("Time Band")["Time Delay(Minutes)"].mean().reindex(b.index).fillna(0).round(1)
    order = [lbl for _, _, lbl in TIME_BANDS]
    b = b.reindex(order).reset_index().rename(columns={"index": "Time Band", "Total_Delayed": "Total Delayed"})

    ws = start_sheet(wb, "Q12 Hour x Delay Reason",
                      "Q12 - Which Hours Cluster with Which Delay Reasons?",
                      "Pivot: Delay Reason x Departure Hour | Delay Count Heatmap by Time Band", 8)
    r = write_table(ws, 4, "12A - Delay Reason Count by Hour", a)
    write_table(ws, r, "12B - Total Delays by Time Band", b)


def q13(wb, df):
    order = ["Same Day", "1-3 Days", "4-7 Days", "8-30 Days", "30+ Days"]
    a = df.groupby("Lead Time", observed=True).agg(Total_Trips=("Price", "size"))
    a["Delayed"] = df[df["Journey Status"] == "Delayed"].groupby(
        "Lead Time", observed=True).size().reindex(a.index).fillna(0).astype(int)
    a["Cancelled"] = df[df["Journey Status"] == "Cancelled"].groupby(
        "Lead Time", observed=True).size().reindex(a.index).fillna(0).astype(int)
    a["Delay %"] = (a["Delayed"] / a["Total_Trips"] * 100).round(1)
    a["Avg Price (£)"] = df.groupby("Lead Time", observed=True)["Price"].mean().round(1)
    a["Refund %"] = (df.groupby("Lead Time", observed=True)["Is Refund"].mean() * 100).round(1)
    a = a.reindex(order).dropna(how="all").reset_index().rename(columns={"Total_Trips": "Total Trips"})

    b = df.pivot_table(index="Lead Time", columns="Ticket Type", values="Price",
                        aggfunc="mean", observed=True, fill_value=0).round(1)
    b = b.reindex(order).dropna(how="all")
    numeric_cols = list(b.columns)
    b["Cheapest Type"] = b[numeric_cols].idxmin(axis=1)
    if "Same Day" in b.index:
        same_day_avg = b.loc["Same Day", numeric_cols].mean()
        b["Price Saving vs Same Day (£)"] = (same_day_avg - b[numeric_cols].mean(axis=1)).round(1)
    b = b.reset_index()

    ws = start_sheet(wb, "Q13 Purchase Lead Time",
                      "Q13 - Does Booking in Advance Affect Price, Delays & Refunds?",
                      "Pivot: Lead Time Group x Journey Outcome | Avg Price by Lead Time | "
                      "Refund Behaviour by Booking Window", 7)
    r = write_table(ws, 4, "13A - Journey Performance by Purchase Lead Time", a)
    same_day_delay = a[a["Lead Time"] == "Same Day"]["Delay %"].values
    other_delay = a[a["Lead Time"] != "Same Day"]["Delay %"].min() if len(a) > 1 else None
    if len(same_day_delay) and other_delay is not None:
        r = write_note(ws, r,
            f"Note: the delay-rate gap between booking same-day ({same_day_delay[0]}%) "
            f"and booking ahead ({other_delay}%) is fairly small, suggesting booking "
            f"lead time doesn't strongly affect delay risk. Price is the more useful angle.", span=7)
    write_table(ws, r, "13B - Avg Price by Ticket Type x Lead Time", b)


def q14(wb, df):
    a = df.groupby("Journey Status").agg(Total_Trips=("Price", "size"))
    a["Refunds"] = df[df["Is Refund"]].groupby("Journey Status").size().reindex(a.index).fillna(0).astype(int)
    a["Refund Rate %"] = (a["Refunds"] / a["Total_Trips"] * 100).round(1)
    a["Avg Delay (min)"] = df[df["Journey Status"] == "Delayed"].groupby(
        "Journey Status")["Time Delay(Minutes)"].mean().reindex(a.index).fillna(0).round(1)
    a["Avg Ticket Price (£)"] = df.groupby("Journey Status")["Price"].mean().round(1)
    total_refunds = a["Refunds"].sum()
    a["% of All Refunds"] = (a["Refunds"] / total_refunds * 100).round(1) if total_refunds else 0
    a = a.reset_index().rename(columns={"Total_Trips": "Total Trips"})

    delayed = df[df["Journey Status"] == "Delayed"]
    b = delayed.groupby("Reason for Delay").agg(Total_Affected=("Price", "size"), Avg_Price=("Price", "mean"))
    b["Refunds"] = delayed[delayed["Is Refund"]].groupby(
        "Reason for Delay").size().reindex(b.index).fillna(0).astype(int)
    b["Refund Rate %"] = (b["Refunds"] / b["Total_Affected"] * 100).round(1)
    b["Avg Delay (min)"] = delayed.groupby("Reason for Delay")["Time Delay(Minutes)"].mean().reindex(b.index).round(1)
    b["Avg Price (£)"] = b.pop("Avg_Price").round(1)
    b = b.sort_values("Refund Rate %", ascending=False).reset_index().rename(columns={"Total_Affected": "Total Affected"})
    b.insert(len(b.columns), "Rank by Refund Rate", range(1, len(b) + 1))

    c = df.groupby(["Ticket Class", "Has Railcard"]).agg(Total=("Price", "size"), Avg_Price=("Price", "mean"))
    c["Refunds"] = df[df["Is Refund"]].groupby(
        ["Ticket Class", "Has Railcard"]).size().reindex(c.index).fillna(0).astype(int)
    c["Refund %"] = (c["Refunds"] / c["Total"] * 100).round(1)
    c["Avg Price (£)"] = c.pop("Avg_Price").round(1)
    c = c.reset_index().rename(columns={"Has Railcard": "Railcard Status"})

    ws = start_sheet(wb, "Q14 Refund Analysis",
                      "Q14 - What Drives Refund Requests & Which Passengers Claim Most?",
                      "Pivot: Refund by Journey Status | Refund by Delay Reason | "
                      "Refund by Ticket Class & Railcard", 7)
    r = write_table(ws, 4, "14A - Refund Requests by Journey Status", a)
    r = write_table(ws, r, "14B - Refund Rate by Delay Reason", b)
    write_table(ws, r, "14C - Refund Rate by Ticket Class x Railcard Status", c)


def q15(wb, df):
    total = len(df)
    delayed = df[df["Journey Status"] == "Delayed"]
    cancelled = df[df["Journey Status"] == "Cancelled"]
    on_time = df[df["Journey Status"] == "On Time"]
    refunds = df[df["Is Refund"]]

    def delay_rate_by(col):
        tot = df.groupby(col).size()
        dly = delayed.groupby(col).size().reindex(tot.index).fillna(0)
        return (dly / tot * 100).round(1)

    reason_share = (delayed["Reason for Delay"].value_counts(normalize=True) * 100).round(1)
    station_delay = delay_rate_by("Departure Station")
    route_sizes = df.groupby("Route").size()
    route_delay_all = delay_rate_by("Route")
    route_delay = route_delay_all[route_sizes.reindex(route_delay_all.index) >= 50]
    busiest = df["Departure Station"].value_counts().idxmax()
    dest_rev_series = df.groupby("Arrival Destination")["Price"].sum()
    dest_rev = dest_rev_series.idxmax()
    hour_delay = delay_rate_by("Departure Hour").dropna()
    day_delay = delay_rate_by("Journey Day")

    rows = [
        ("Total Journeys", f"{total:,}", ""),
        ("Total Revenue (£)", f"{df['Price'].sum():,.0f}", ""),
        ("On-Time Journeys", f"{len(on_time):,}", f"{pct(len(on_time), total)}%"),
        ("Delayed Journeys", f"{len(delayed):,}", f"{pct(len(delayed), total)}%"),
        ("Cancelled Journeys", f"{len(cancelled):,}", f"{pct(len(cancelled), total)}%"),
        ("Total Refund Requests", f"{len(refunds):,}", f"{pct(len(refunds), total)}%"),
        ("Avg Delay (Delayed Only)", f"{delayed['Time Delay(Minutes)'].mean():.1f} min", ""),
        ("Total Delay Minutes", f"{delayed['Time Delay(Minutes)'].sum():,.0f}", ""),
        ("Most Common Delay Reason", f"{reason_share.idxmax()} ({reason_share.max()}%)", ""),
        ("Highest Pressure Station", f"{station_delay.idxmax()} ({station_delay.max():.0f}% delay rate)", ""),
        ("Most Vulnerable Route", f"{route_delay.idxmax()} ({route_delay.max():.1f}%)", ""),
        ("Busiest Departure Station", f"{busiest} ({df['Departure Station'].value_counts().max():,} trips)", ""),
        ("Highest Revenue Dest.", f"{dest_rev} (£{dest_rev_series.max():,.0f})", ""),
        ("Peak Delay Hour", f"{int(hour_delay.idxmax()):02d}:00 ({hour_delay.max():.1f}% delay rate)", ""),
        ("Best On-Time Day", f"{day_delay.idxmin()} ({100 - day_delay.min():.1f}% on time)", ""),
        ("Worst Delay Day", f"{day_delay.idxmax()} ({day_delay.max():.1f}% delay rate)", ""),
    ]
    kpis = pd.DataFrame(rows, columns=["KPI", "Value", "Extra"])

    ws = start_sheet(wb, "Q15 KPI Summary",
                      "Q15 - What Is the Overall KPI Scorecard Across All Dimensions?",
                      "Master Summary: Volume | Revenue | Delay | Cancellation | Refund | Worst & Best Performers", 7)
    write_table(ws, 4, "15A - Top-Level Network KPIs", kpis)


def main():
    df = load_data()

    wb = openpyxl.Workbook()
    wb.remove(wb.active)

    data_ws = wb.create_sheet("Data")
    data_ws["A1"] = "Railway Dataset - Cleaned Fact Table"
    data_ws["A2"] = f"Source data used for all Pivot Tables below | {len(df):,} rows"
    helper_cols = {"Departure Hour", "Route", "Is Refund", "Time Band", "Lead Time", "Price Tier", "Month"}
    cols = [c for c in df.columns if c not in helper_cols]
    for j, col in enumerate(cols, start=1):
        data_ws.cell(row=3, column=j, value=col).font = HEADER_FONT
    for i, (_, row) in enumerate(df[cols].iterrows(), start=4):
        for j, val in enumerate(row, start=1):
            data_ws.cell(row=i, column=j, value=val)

    for fn in (q1, q2, q3, q4, q5, q6, q7, q8, q9, q10, q11, q12, q13, q14, q15):
        fn(wb, df)

    wb.save(OUT_PATH)
    print(f"Saved {OUT_PATH}")


if __name__ == "__main__":
    main()
